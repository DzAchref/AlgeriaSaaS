# ========================
# Algeria SaaS Ecosystem
# Environment Configuration
# ========================

# Application
NODE_ENV=development
APP_PORT=3000

# Database — PostgreSQL 16
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=algeria_saas
DATABASE_USER=algeria_saas_user
DATABASE_PASSWORD=changeme_dev_password
DATABASE_URL=postgresql://algeria_saas_user:changeme_dev_password@localhost:5432/algeria_saas

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# JWT Auth
JWT_SECRET=changeme_jwt_secret_at_least_32_chars
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=604800

# Payment Providers
CHARGILY_API_KEY=
CHARGILY_SECRET_KEY=
CHARGILY_WEBHOOK_SECRET=
SATIM_TERMINAL_ID=
SATIM_MERCHANT_ID=

# Notification Channels
WHATSAPP_BSP_API_URL=
WHATSAPP_BSP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
SMS_GATEWAY_API_KEY=
SMS_GATEWAY_SENDER_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Algeria Compliance
DGI_E_INVOICE_ENDPOINT=
ANPDP_CONSENT_MODE=strict

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Logging
LOG_LEVEL=debug
